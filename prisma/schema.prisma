// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

generator client2 {
  provider = "prisma-client-py"
  recursive_type_depth = -1
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Stocks {
  id   Int    @id @default(autoincrement())
  code String @unique
  name String
}

model Stockprices {
  stock_id Int
  date     String
  date_num Int
  open     Float
  close    Float
  high     Float
  low      Float
  volume   Int

  @@id([stock_id, date])
}

model SignalSmashday {
  stock_id      Int
  date          DateTime
  smashday_buy  Boolean
  smashday_sell Boolean

  @@id([stock_id, date])
}

model Form {
  id      Int      @id @default(autoincrement())
  date    DateTime @default(now())
  message String
  done    Boolean  @default(false)
}
